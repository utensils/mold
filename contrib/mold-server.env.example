# mold-server runtime environment.
# Install at ~/.config/mold/server.env (user mode) or /etc/mold/mold.env
# (system mode), then `chmod 600`.

# Hugging Face token — needed by `mold pull` and `mold catalog refresh`
# for gated repos and to bypass anonymous rate limits.
HF_TOKEN=hf_replace_me

# Civitai API token — needed by `mold catalog refresh` to walk Civitai's
# API at the higher authenticated rate limit. Optional; absent token
# still returns most public catalog rows.
CIVITAI_TOKEN=replace_me

# Optional: API key gate for the HTTP server. Clients must send
# `Authorization: Bearer <key>`.
# MOLD_API_KEY=replace_me

# Optional: rate limit (per IP) and burst.
# MOLD_RATE_LIMIT=10/min
# MOLD_RATE_LIMIT_BURST=20

# Optional: tighter logging.
# MOLD_LOG=warn
